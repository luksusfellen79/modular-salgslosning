INTEGRATION_PORT=3010
NODE_ENV=development
LOG_LEVEL=info

# Kilde-system URL-er (mock i dev, ekte i prod)
FIBER_SYSTEM_URL=http://localhost:4001
MOBILE_SYSTEM_URL=http://localhost:4002
TV_SYSTEM_URL=http://localhost:4003
PRICING_SYSTEM_URL=http://localhost:4004

# Kafka (brukes ikke i mock-modus)
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=integration-layer
KAFKA_ENABLED=false

# Cache TTL i sekunder
CACHE_TTL_PRODUCTS=300
CACHE_TTL_CUSTOMERS=60
CACHE_TTL_PRICING=120

# E-post (EmailAdapter)
EMAIL_PROVIDER=disabled
EMAIL_FROM=noreply@telenor.no
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
