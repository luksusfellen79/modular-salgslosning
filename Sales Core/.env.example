SALESCORE_PORT=3005
NODE_ENV=development
SALES_CORE_BASE_URL=http://localhost:3005

# PostgreSQL (Railway) — når satt brukes hub.* og sales_core.* i stedet for JSON-filer
DATABASE_URL=postgresql://user:password@host:5432/railway
# Sett PGSSL_DISABLE=true for lokal Postgres uten SSL
# PGSSL_DISABLE=true

# JSON-fallback (kun uten DATABASE_URL / lokale tester)
# DATA_DIR=./data
